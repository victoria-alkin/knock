# Copy this file to `.env` and fill in your key.
#
# Server-only secret used by the Places proxy in src/app/api/*.
# Do NOT prefix it with EXPO_PUBLIC_ — that would bundle the key into the
# client app, where anyone can extract it.
#
# How to get a key:
#   1. https://console.cloud.google.com/ → create/select a project
#   2. Enable the "Places API (New)" service
#   3. APIs & Services → Credentials → Create credentials → API key
#   4. (Recommended) Restrict the key to the Places API (New)
GOOGLE_PLACES_API_KEY=

# Supabase — PUBLIC values (safe to commit/ship; guarded by Row Level Security).
# Find them in your Supabase project: Connect button, or Settings -> API Keys.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
